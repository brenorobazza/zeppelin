[flake8]
max-line-length = 88
extend-ignore = E203, W503, E501, F403, F405
exclude =
    .git,
    __pycache__,
    .venv,
    .env,
    venv,
    migrations,
    .tox,
    .pytest_cache,
    .eggs,
    *.egg,
    build,
    dist

per-file-ignores =
    **/migrations/*.py:F403,F405,E501
    **/settings/*.py:F403,F405
    src/apps/organization/services.py:F821
